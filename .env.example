# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Kubernetes Configuration
# Leave empty to use default kubeconfig (~/.kube/config)
KUBECONFIG_PATH=
# Default namespace to use (optional)
K8S_NAMESPACE=default

# Consul Configuration
# Use host:port format for python-consul (do not include http:// or https://)
CONSUL_HTTP_ADDR=127.0.0.1:8500
# Consul ACL token SecretID (required for ACL-enabled clusters)
CONSUL_HTTP_TOKEN=
# Set to 'true' if using HTTPS
CONSUL_HTTP_SSL=false
# Set to 'false' only for local troubleshooting with self-signed certificates
CONSUL_HTTP_SSL_VERIFY=true
# Preferred for HTTPS with a private CA
CONSUL_CACERT=
# Consul datacenter (optional)
CONSUL_DATACENTER=dc1

# Agent Configuration
# Model to use (gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo)
LLM_MODEL=gpt-4-turbo-preview
# Temperature for responses (0.0 - 1.0)
LLM_TEMPERATURE=0.1
# Enable verbose logging
VERBOSE=false